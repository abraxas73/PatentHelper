# AWS Deployment Environment Variables

# AWS Configuration
AWS_REGION=ap-northeast-2
AWS_ACCOUNT_ID=857201044807

# Environment
ENVIRONMENT=prod

# Stack Configuration
STACK_NAME=patent-helper-prod

# Domain Configuration (optional)
DOMAIN_NAME=patent-drawing.sncbears.cloud
USE_CUSTOM_DOMAIN=false

# ECS Configuration
ECR_REPO_NAME=patent-helper-ocr
ECS_TASK_CPU=512
ECS_TASK_MEMORY=1024

# Lambda Configuration
LAMBDA_TIMEOUT=30
LAMBDA_MEMORY=512

# S3 Configuration
S3_EXPIRY_DAYS=7

# DynamoDB Configuration
DYNAMODB_READ_CAPACITY=5
DYNAMODB_WRITE_CAPACITY=5

# SQS Configuration
SQS_VISIBILITY_TIMEOUT=300
SQS_MESSAGE_RETENTION=86400

# Cost Optimization
USE_FARGATE_SPOT=true
SPOT_MAX_PRICE=0.05