# Production Environment Variables
APP_NAME=PatentHelper
APP_VERSION=1.0.0
ENVIRONMENT=production

# API Settings
API_HOST=0.0.0.0
API_PORT=8000

# CORS Settings
CORS_ORIGINS=["http://patent.sncbears.cloud", "https://patent.sncbears.cloud"]

# File Upload Settings
MAX_UPLOAD_SIZE=104857600  # 100MB in bytes
ALLOWED_EXTENSIONS=["pdf"]

# OCR Settings
OCR_LANGUAGES=["ko", "en"]
USE_GPU=false

# Logging
LOG_LEVEL=INFO
LOG_FILE=/app/logs/patent_helper.log